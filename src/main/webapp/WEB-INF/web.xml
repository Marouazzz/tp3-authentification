<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE web-app PUBLIC
        "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
        "http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>

    <!-- 1. TOUS LES FILTRES D'ABORD -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>servlet.AuthFilter</filter-class>
    </filter>

    <!-- 2. TOUS LES MAPPINGS DE FILTRES -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/home.jsp</url-pattern>
    </filter-mapping>

    <!-- 3. TOUTES LES SERVLETS -->
    <servlet>
        <servlet-name>UserServlet</servlet-name>
        <servlet-class>servlet.UserServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>InscriptionServlet</servlet-name>
        <servlet-class>servlet.InscriptionServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>DeconnServlet</servlet-name>
        <servlet-class>servlet.DeconnServlet</servlet-class>
    </servlet>

    <!-- 4. TOUS LES MAPPINGS DE SERVLETS -->
    <servlet-mapping>
        <servlet-name>UserServlet</servlet-name>
        <url-pattern>/UserServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>InscriptionServlet</servlet-name>
        <url-pattern>/InscriptionServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>DeconnServlet</servlet-name>
        <url-pattern>/DeconnServlet</url-pattern>
    </servlet-mapping>

    <!-- 5. LE RESTE -->
    <welcome-file-list>
        <welcome-file>inscription.jsp</welcome-file>
    </welcome-file-list>

</web-app>